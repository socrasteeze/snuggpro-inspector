# SnuggPro API credentials
# Generate at: Settings > Your Companies > Your company > App Integrations > Generate API Key
# Copy this file to .env and fill in your real keys. Never commit .env.

SNUGG_PUBLIC_KEY=your_public_key_here
SNUGG_PRIVATE_KEY=your_private_key_here

# Optional: override the proxy port (default 3001)
# PORT=3001
